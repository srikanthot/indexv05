    {
      "@odata.type": "#Microsoft.Skills.Util.ConditionalSkill",
      "name": "gate-text-embedding-input",
      "description": "Cost gate: pass chunk_for_semantic to the embedding skill ONLY when processing_status != 'toc_like'. TOC chunks are filtered at retrieval anyway, so embedding them was pure cost.",
      "context": "/document/markdownDocument/*/pages/*",
      "inputs": [
        { "name": "condition", "source": "= $(/document/markdownDocument/*/pages/*/text_processing_status) != 'toc_like'" },
        { "name": "whenTrue", "source": "/document/markdownDocument/*/pages/*/text_chunk_for_semantic" },
        { "name": "whenFalse", "source": "= ''" }
      ],
      "outputs": [
        { "name": "output", "targetName": "text_chunk_for_embedding" }
      ]
    },

