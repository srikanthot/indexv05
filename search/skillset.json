{
  "name": "mm-manuals-skillset",
  "description": "Multimodal manual skillset v2: layout + DI-direct figure/table enrichment + per-figure vision + per-context embeddings",

  "skills": [

    {
      "@odata.type": "#Microsoft.Skills.Util.DocumentIntelligenceLayoutSkill",
      "name": "layout-skill",
      "description": "Built-in DI layout for the markdown text path (h1-h3 sections, page chunks)",
      "context": "/document",
      "outputMode": "oneToMany",
      "markdownHeaderDepth": "h3",
      "inputs": [
        { "name": "file_data", "source": "/document/file_data" }
      ],
      "outputs": [
        { "name": "markdown_document", "targetName": "markdownDocument" }
      ]
    },

    {
      "@odata.type": "#Microsoft.Skills.Text.SplitSkill",
      "name": "split-pages",
      "description": "Chunk each layout section into overlapping pages",
      "context": "/document/markdownDocument/*",
      "defaultLanguageCode": "en",
      "textSplitMode": "pages",
      "maximumPageLength": 1200,
      "pageOverlapLength": 200,
      "unit": "characters",
      "inputs": [
        { "name": "text", "source": "/document/markdownDocument/*/content" }
      ],
      "outputs": [
        { "name": "textItems", "targetName": "pages" }
      ]
    },

    {
      "@odata.type": "#Microsoft.Skills.Custom.WebApiSkill",
      "name": "process-document-skill",
      "description": "Calls Azure DI directly to extract per-figure crops + per-table markdown with section enrichment",
      "context": "/document",
      "uri": "https://<FUNCTION_APP_HOST>/api/process-document?code=<FUNCTION_KEY>",
      "httpMethod": "POST",
      "timeout": "PT230S",
      "batchSize": 1,
      "degreeOfParallelism": 2,
      "inputs": [
        { "name": "source_file", "source": "/document/metadata_storage_name" },
        { "name": "source_path", "source": "/document/metadata_storage_path" }
      ],
      "outputs": [
        { "name": "enriched_figures", "targetName": "enriched_figures" },
        { "name": "enriched_tables", "targetName": "enriched_tables" },
        { "name": "processing_status", "targetName": "doc_processing_status" },
        { "name": "skill_version", "targetName": "doc_skill_version" }
      ]
    },

    {
